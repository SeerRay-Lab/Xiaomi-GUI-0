<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络 & 前台服务 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <!-- 后台启 Activity 的豁免凭证。MIUI/HyperOS 在 AOSP BAL 之上额外要 MIUIOP 10021
         「后台弹出界面」；该 op 无法用 requestPermissions 请求，但部分 MIUI 版本会把
         SYSTEM_ALERT_WINDOW 作为放行依据。这个权限仅声明 + 引导用户，`canDrawOverlays`
         默认 false，不会自动触发 UI 悬浮窗。 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 扫码配对：相机预览 + ML Kit 条码识别 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".GuinessApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GuinessController"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 扫码配对 Activity：CameraX 预览 + ML Kit 识码 + 回拨 PC -->
        <activity
            android:name=".ui.ScanActivity"
            android:exported="false"
            android:label="扫码配对"
            android:screenOrientation="portrait"
            tools:ignore="LockedOrientationActivity" />

        <!-- 控制服务：持 MediaProjection + 跑 Ktor server -->
        <service
            android:name=".service.ControlForegroundService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection|specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Guiness remote control HTTP server (LAN only)" />
        </service>

        <!-- 无障碍服务：唯一的手势/按键注入通道，不需 ROOT / ADB -->
        <service
            android:name=".service.ControlAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
    </application>
</manifest>
